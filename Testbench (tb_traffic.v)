`timescale 1ns/1ps

module tb_traffic;

reg clk;
reg rst;
wire [2:0] light;

traffic_light uut (
    .clk(clk),
    .rst(rst),
    .light(light)
);

always #5 clk = ~clk;

initial begin

    $dumpfile("traffic.vcd");
    $dumpvars(0, tb_traffic);

    clk = 0;
    rst = 1;

    #15 rst = 0;

    #100;

    $finish;
end

endmodule
